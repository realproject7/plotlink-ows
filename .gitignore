# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# archive (data exports, scored CSVs — never commit)
archive/

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
dist

# misc
.DS_Store
*.pem

# secrets & keys — NEVER commit these
.plotlinkrc
*.key
*.secret
*.p12
*.pfx
credentials.json
serviceAccountKey.json
*.keystore

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/worktrees/
AGENTS.md

# test results
test-results/
playwright-report/

# supabase temp
supabase/.temp/
